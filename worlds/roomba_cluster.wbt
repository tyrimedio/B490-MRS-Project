# ============================================================
# Docking station marker in central hub
# ============================================================
DEF DOCKING_STATION Solid {
  translation 0 0 0.005
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.2 0.6 0.2
        roughness 0.5
      }
      geometry Cylinder {
        height 0.01
        radius 0.15
      }
    }
  ]
  name "docking_station"
}

# ============================================================
# E-puck robots (4 robots starting near the docking station)
# ============================================================
DEF EPUCK_1 E-puck {
  translation -0.15 0.15 0
  rotation 0 0 1 0
  name "epuck_1"
  controller "roomba_controller"
  turretSlot [
    DEF LIDAR DistanceSensor {
      name "lidar"
      lookupTable [
        0 0 0
        1.0 1000 0
      ]
    }
  ]
}
DEF EPUCK_2 E-puck {
  translation 0.15 0.15 0
  rotation 0 0 1 1.5708
