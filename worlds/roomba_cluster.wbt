#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/robots/gctronic/e-puck/protos/E-puck.proto"

WorldInfo {
  info [
    "Roomba Cluster: Multi-Robot Autonomous Cleaning System"
    "4 rooms connected by a central hub with docking station"
  ]
  title "Roomba Cluster Simulation"
  basicTimeStep 16
}
Viewpoint {
  orientation -0.577 0.577 0.577 2.094
  position 0 0 12
}
TexturedBackground {
}
TexturedBackgroundLight {
}

# Main floor arena (6m x 6m total footprint)
RectangleArena {
  translation 0 0 0
  floorSize 6 6
  floorTileSize 0.5 0.5
  wallHeight 0.15
  wallThickness 0.02
}

# ============================================================
# Interior walls defining 4 rooms + central hub
# Layout:
#   +-------+---+-------+
#   | Room1 |   | Room2 |
#   | (NW)  | d | (NE)  |
#   +--[ ]--+   +--[ ]--+
#   |     Central Hub    |
#   +--[ ]--+   +--[ ]--+
#   | Room3 |   | Room4 |
#   | (SW)  |   | (SE)  |
#   +-------+---+-------+
#
# Central hub: 2m x 2m in the center
# Each room: ~2m x 2m in the corners
# Doorways: 0.6m openings connecting rooms to hub
# ============================================================

# --- North wall segments (between NW room / hub / NE room) ---
DEF WALL_N_LEFT Solid {
  translation -2.0 1.0 0.075
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.7 0.7 0.7
        roughness 0.8
      }
      geometry Box {
        size 0.7 0.02 0.15
      }
    }
  ]
  name "wall_n_left"
  boundingObject Box {
    size 0.7 0.02 0.15
  }
}
DEF WALL_N_RIGHT Solid {
  translation 2.0 1.0 0.075
  children [
